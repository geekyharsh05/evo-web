# Server Environment Variables Example
# Copy this file to server/.env and fill in your actual values

# Database Configuration
_change_me@localhost:5432/evo_site_builder

# AI Service (OpenRouter)
AI_API_KEY=your-openrouter-api-key-here

# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Authentication
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-random-secret-min-32-characters

# Backend URL
BETTER_AUTH_URL=http://localhost:3000

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173

# CORS - Comma separated list of allowed origins
TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

# Resend API Key for sending emails
RESEND_API_KEY=re_h6DZeEi7_6wSvwY3NGHT8X7JHYTGdVA69

# Environment
NODE_ENV=development

